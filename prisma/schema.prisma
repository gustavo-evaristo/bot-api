// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id        String   @id @default(uuid())
  isActive  Boolean  @default(true)
  name      String
  email     String   @unique
  phone     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  flows         flows[]
  forms         forms[]
  kanbans       kanbans[]
  quick_replies quick_replies[]
}

model flows {
  id          String          @id @default(uuid())
  userId      String
  user        users           @relation(fields: [userId], references: [id])
  kanbanId    String?
  kanban      kanbans?        @relation(fields: [kanbanId], references: [id])
  isActive    Boolean         @default(true)
  isDeleted   Boolean         @default(false)
  title       String
  description String?
  phoneNumber String?
  startNodeId String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  nodes         flow_nodes[]
  conversations conversations[]
}

model flow_nodes {
  id                String         @id @default(uuid())
  flowId            String
  flow              flows          @relation(fields: [flowId], references: [id])
  kanbanStageId           String?
  kanbanStage             kanban_stages? @relation("NodeCurrentStage", fields: [kanbanStageId], references: [id])
  postFillKanbanStageId   String?
  postFillKanbanStage     kanban_stages? @relation("NodePostFillStage", fields: [postFillKanbanStageId], references: [id])
  formId            String?
  form              forms?         @relation(fields: [formId], references: [id])
  isDeleted         Boolean        @default(false)
  type              String
  content           String
  defaultNextNodeId String?
  defaultNextNode   flow_nodes?    @relation("NodeNext", fields: [defaultNextNodeId], references: [id])
  prevNodes         flow_nodes[]   @relation("NodeNext")
  incomingFromOpts  node_options[] @relation("OptionNext")
  x                 Float          @default(0)
  y                 Float          @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  options           node_options[]
}

model node_options {
  id         String      @id @default(uuid())
  nodeId     String
  node       flow_nodes  @relation(fields: [nodeId], references: [id])
  isDeleted  Boolean     @default(false)
  content    String
  score      Int         @default(0)
  order      Int         @default(0)
  nextNodeId String?
  nextNode   flow_nodes? @relation("OptionNext", fields: [nextNodeId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model conversations {
  id                String                  @id @default(uuid())
  flowId            String
  flow              flows                   @relation(fields: [flowId], references: [id])
  leadPhoneNumber   String
  leadName          String?
  status            String                  @default("ACTIVE")
  automationEnabled Boolean                 @default(true)
  isDeleted         Boolean                 @default(false)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  progress          conversation_progress?
  leadResponses     lead_responses[]
  messageHistory    message_history[]
}

model message_history {
  id             String        @id @default(uuid())
  conversationId String
  conversation   conversations @relation(fields: [conversationId], references: [id])
  sender         String
  content        String
  createdAt      DateTime      @default(now())
}

model conversation_progress {
  id                      String        @id @default(uuid())
  conversationId          String        @unique
  conversation            conversations @relation(fields: [conversationId], references: [id])
  currentNodeId           String
  lastKanbanStageId       String?
  waitingForResponse      Boolean       @default(false)
  waitingForResponseSince DateTime?
  followUpSentAt          DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
}

model lead_responses {
  id             String        @id @default(uuid())
  conversationId String
  conversation   conversations @relation(fields: [conversationId], references: [id])
  nodeId         String
  nodeOptionId   String?
  responseText   String
  score          Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model whatsapp_sessions {
  id        String   @id @default(uuid())
  userId    String   @unique
  creds     String?
  keys      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model instance_lock {
  lockKey    String   @id
  instanceId String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model quick_replies {
  id        String   @id @default(uuid())
  userId    String
  user      users    @relation(fields: [userId], references: [id])
  shortcut  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model kanbans {
  id          String          @id @default(uuid())
  userId      String
  user        users           @relation(fields: [userId], references: [id])
  title       String
  description String?
  isDeleted   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  stages      kanban_stages[]
  flows       flows[]
}

model kanban_stages {
  id        String       @id @default(uuid())
  kanbanId  String
  kanban    kanbans      @relation(fields: [kanbanId], references: [id])
  title     String
  color     String?
  order     Int          @default(0)
  isDeleted Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  nodes             flow_nodes[] @relation("NodeCurrentStage")
  postFillNodes     flow_nodes[] @relation("NodePostFillStage")
}

model forms {
  id          String           @id @default(uuid())
  userId      String
  user        users            @relation(fields: [userId], references: [id])
  title       String
  description String?
  token       String           @unique @default(uuid())
  isActive    Boolean          @default(false)
  isDeleted   Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  fields      form_fields[]
  responses   form_responses[]
  flowNodes   flow_nodes[]
}

model form_fields {
  id          String               @id @default(uuid())
  formId      String
  form        forms                @relation(fields: [formId], references: [id])
  isDeleted   Boolean              @default(false)
  type        String
  title       String?
  label       String
  placeholder String?
  required    Boolean              @default(false)
  order       Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  options     form_field_options[]
  answers     form_answers[]
}

model form_field_options {
  id        String      @id @default(uuid())
  fieldId   String
  field     form_fields @relation(fields: [fieldId], references: [id])
  isDeleted Boolean     @default(false)
  label     String
  order     Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model form_responses {
  id        String         @id @default(uuid())
  formId    String
  form      forms          @relation(fields: [formId], references: [id])
  isDeleted Boolean        @default(false)
  createdAt DateTime       @default(now())
  answers   form_answers[]
}

model form_answers {
  id         String         @id @default(uuid())
  responseId String
  response   form_responses @relation(fields: [responseId], references: [id])
  fieldId    String
  field      form_fields    @relation(fields: [fieldId], references: [id])
  value      String
  createdAt  DateTime       @default(now())
}
