// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id        String   @id @default(uuid())
  isActive  Boolean  @default(true)
  name      String
  email     String   @unique
  phone     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  flows     flows[]
}

model flows {
  id          String          @id @default(uuid())
  userId      String
  user        users           @relation(fields: [userId], references: [id])
  isActive    Boolean         @default(true)
  isDeleted   Boolean         @default(false)
  title       String
  phoneNumber String?
  startNodeId String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  nodes         flow_nodes[]
  conversations conversations[]
}

model flow_nodes {
  id                String         @id @default(uuid())
  flowId            String
  flow              flows          @relation(fields: [flowId], references: [id])
  isDeleted         Boolean        @default(false)
  type              String
  content           String
  defaultNextNodeId String?
  defaultNextNode   flow_nodes?    @relation("NodeNext", fields: [defaultNextNodeId], references: [id])
  prevNodes         flow_nodes[]   @relation("NodeNext")
  incomingFromOpts  node_options[] @relation("OptionNext")
  x                 Float          @default(0)
  y                 Float          @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  options           node_options[]
}

model node_options {
  id         String      @id @default(uuid())
  nodeId     String
  node       flow_nodes  @relation(fields: [nodeId], references: [id])
  isDeleted  Boolean     @default(false)
  content    String
  score      Int         @default(0)
  order      Int         @default(0)
  nextNodeId String?
  nextNode   flow_nodes? @relation("OptionNext", fields: [nextNodeId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model conversations {
  id              String                  @id @default(uuid())
  flowId          String
  flow            flows                   @relation(fields: [flowId], references: [id])
  leadPhoneNumber String
  leadName        String?
  status          String                  @default("ACTIVE")
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  progress        conversation_progress?
  leadResponses   lead_responses[]
  messageHistory  message_history[]
}

model message_history {
  id             String        @id @default(uuid())
  conversationId String
  conversation   conversations @relation(fields: [conversationId], references: [id])
  sender         String
  content        String
  createdAt      DateTime      @default(now())
}

model conversation_progress {
  id                      String        @id @default(uuid())
  conversationId          String        @unique
  conversation            conversations @relation(fields: [conversationId], references: [id])
  currentNodeId           String
  waitingForResponse      Boolean       @default(false)
  waitingForResponseSince DateTime?
  followUpSentAt          DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
}

model lead_responses {
  id             String        @id @default(uuid())
  conversationId String
  conversation   conversations @relation(fields: [conversationId], references: [id])
  nodeId         String
  nodeOptionId   String?
  responseText   String
  score          Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model whatsapp_sessions {
  id        String   @id @default(uuid())
  userId    String   @unique
  creds     String?
  keys      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model instance_lock {
  lockKey    String   @id
  instanceId String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
