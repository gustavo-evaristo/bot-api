// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id        String    @id @default(uuid())
  isActive  Boolean   @default(true)
  name      String
  email     String    @unique
  phone     String    @unique
  password  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  kanbans   kanbans[]
}

model kanbans {
  id          String   @id @default(uuid())
  userId      String
  user        users    @relation(fields: [userId], references: [id])
  isActive    Boolean  @default(true)
  isDeleted   Boolean  @default(false)
  title       String
  description String
  imageUrl    String?
  phoneNumber String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stages        stages[]
  conversations conversations[]
}

model stages {
  id            String           @id @default(uuid())
  kanbanId      String
  kanban        kanbans          @relation(fields: [kanbanId], references: [id])
  isDeleted     Boolean          @default(false)
  title         String
  description   String
  order         Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  stageContents stage_contents[]
}

model stage_contents {
  id             String          @id @default(uuid())
  stageId        String
  stage          stages          @relation(fields: [stageId], references: [id])
  isDeleted      Boolean         @default(false)
  content        String
  contentType    String
  order          Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  answers        answers[]
  leadResponses  lead_responses[]
}

model answers {
  id             String          @id @default(uuid())
  stageContentId String
  stageContent   stage_contents  @relation(fields: [stageContentId], references: [id])
  isDeleted      Boolean         @default(false)
  content        String
  score          Int
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  leadResponses  lead_responses[]
}

model conversations {
  id              String                  @id @default(uuid())
  kanbanId        String
  kanban          kanbans                 @relation(fields: [kanbanId], references: [id])
  leadPhoneNumber String
  status          String                  @default("ACTIVE")
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  progress        conversation_progress?
  leadResponses   lead_responses[]
}

model conversation_progress {
  id                    String        @id @default(uuid())
  conversationId        String        @unique
  conversation          conversations @relation(fields: [conversationId], references: [id])
  currentStageId        String
  currentStageContentId String
  waitingForResponse    Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model lead_responses {
  id               String         @id @default(uuid())
  conversationId   String
  conversation     conversations  @relation(fields: [conversationId], references: [id])
  stageContentId   String
  stageContent     stage_contents @relation(fields: [stageContentId], references: [id])
  answerId         String?
  answer           answers?       @relation(fields: [answerId], references: [id])
  responseText     String
  score            Int?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}
